# Fork identity — override in Vercel project settings for production builds.
# In development, the dev fallback is used and a console warning is emitted.
# In production, a missing value causes the build to fail fast.

VITE_POLYHIVE_WEB_APP_URL=https://polyhive-app.vercel.app
VITE_POLYHIVE_SITE_HOST=https://polyhive.vercel.app
VITE_POLYHIVE_GITHUB_REPO=everton-dgn/polyhive
VITE_POLYHIVE_CLI_INSTALL_COMMAND=npm install -g polyhive
VITE_POLYHIVE_CLI_START_COMMAND=polyhive
