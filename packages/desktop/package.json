{
  "name": "polyhive-desktop",
  "version": "0.1.66",
  "private": true,
  "description": "PolyHive desktop app (Electron wrapper)",
  "main": "dist/main.js",
  "scripts": {
    "build": "npm --prefix ../.. run build:daemon && npm run build:main && electron-builder --config electron-builder.yml",
    "build:main": "tsc -p tsconfig.json",
    "dev": "./scripts/dev.sh",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@evertondgn/polyhive-cli": "0.1.66",
    "@evertondgn/polyhive-server": "0.1.66",
    "electron-log": "5.4.3",
    "electron-updater": "6.8.3",
    "ws": "8.19.0"
  },
  "devDependencies": {
    "@types/node": "24.6.0",
    "@types/ws": "8.18.1",
    "electron": "41.0.3",
    "electron-builder": "26.8.1",
    "typescript": "5.9.3",
    "unzip-crx-3": "0.2.0",
    "wait-on": "8.0.5"
  },
  "homepage": "https://github.com/everton-dgn/polyhive",
  "repository": {
    "type": "git",
    "url": "https://github.com/everton-dgn/polyhive.git"
  },
  "author": {
    "name": "Mohamed Boudra",
    "email": "hello@moboudra.com"
  },
  "license": "AGPL-3.0-or-later"
}
