# Fork identity — override in Vercel project settings for production builds.
# In development, the dev fallback is used and a console warning is emitted.
# In production, a missing value causes the build to fail fast.

VITE_PASEO_WEB_APP_URL=https://paseo-contrib.vercel.app
VITE_PASEO_SITE_HOST=https://paseo-contrib.vercel.app
VITE_PASEO_GITHUB_REPO=everton-dgn/paseo-contrib
