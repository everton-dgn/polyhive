{
  "worktree": {
    "setup": [
      "npm ci",
      "npm run build:daemon",
      "cp \"$POLYHIVE_SOURCE_CHECKOUT_PATH/packages/server/.env\" \"$POLYHIVE_WORKTREE_PATH/packages/server/.env\""
    ]
  },
  "scripts": {
    "daemon": {
      "type": "service",
      "command": "POLYHIVE_LISTEN=0.0.0.0:$POLYHIVE_PORT npm run dev:server"
    },
    "app": {
      "type": "service",
      "command": "cd packages/app && BROWSER=none EXPO_PUBLIC_LOCAL_DAEMON=\"${POLYHIVE_SERVICE_DAEMON_URL#http://}\" npx expo start --port $POLYHIVE_PORT"
    },
    "typecheck": {
      "command": "npm run typecheck"
    }
  }
}
